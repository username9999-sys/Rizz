# ===================================
# RIZZ PLATFORM - ENVIRONMENT VARIABLES
# ===================================
# ⚠️ CRITICAL: Change ALL values before ANY deployment!
# These are for LOCAL DEVELOPMENT ONLY!

# ===================================
# DATABASE CREDENTIALS
# ===================================
# Generate strong passwords: openssl rand -base64 32

# PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_USER=rizz_admin

# MongoDB  
MONGO_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
MONGO_INITDB_ROOT_USERNAME=rizz_admin

# Redis
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=rizz_admin
MINIO_SECRET_KEY=CHANGE_ME_GENERATE_STRONG_PASSWORD

# RabbitMQ
RABBITMQ_DEFAULT_USER=rizz_admin
RABBITMQ_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ===================================
# APPLICATION SECRETS
# ===================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# JWT & Authentication
JWT_SECRET_KEY=CHANGE_ME_GENERATE_32_CHAR_HEX_STRING
SECRET_KEY=CHANGE_ME_GENERATE_32_CHAR_HEX_STRING

# API Keys (if using external services)
OPENAI_API_KEY=sk-your-key-here
STRIPE_SECRET_KEY=sk_live_your-key-here
GITHUB_TOKEN=ghp_your-token-here

# ===================================
# SERVICE-SPECIFIC SECRETS
# ===================================

# Grafana
GRAFANA_ADMIN_USER=rizz_admin
GRAFANA_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# Temporal (workflow engine)
TEMPORAL_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# Analytics Service
ANALYTICS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
TIMESCALE_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# Unleash (feature flags)
UNLEASH_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ===================================
# EMAIL CONFIGURATION
# ===================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@yourdomain.com
EMAIL_PASSWORD=your-app-password-here
CONTACT_EMAIL=contact@rizz.dev

# ===================================
# EXTERNAL SERVICE URLs
# ===================================
MONGODB_URI=mongodb://rizz_admin:${MONGO_PASSWORD}@localhost:27017/rizz?authSource=admin
DATABASE_URL=postgresql://rizz_admin:${POSTGRES_PASSWORD}@localhost:5432/rizz_api
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# ===================================
# DISCORD BOT
# ===================================
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-client-id-here

# ===================================
# SECURITY SETTINGS
# ===================================
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
NODE_ENV=development
FLASK_ENV=development

# ===================================
# DEPLOYMENT
# ===================================
# For production, set these:
# - All passwords above
# - DOMAIN=yourdomain.com
# - SSL_CERT_PATH=/path/to/cert.pem
# - SSL_KEY_PATH=/path/to/key.pem

# ===================================
# ⚠️ SECURITY CHECKLIST BEFORE DEPLOY:
# ===================================
# [ ] All PASSWORD fields changed from defaults
# [ ] All SECRET_KEY fields generated (32+ chars)
# [ ] API keys added for services you use
# [ ] CORS_ORIGINS restricted to your domains
# [ ] NODE_ENV=production
# [ ] FLASK_ENV=production
# [ ] SSL certificates configured
# [ ] Database backups configured
# [ ] Monitoring enabled
# [ ] Security scanning completed
